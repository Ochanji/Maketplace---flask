# Copy this file to .env and fill in your values

# Secret key (change this in production!)
SECRET_KEY=change-me-in-production

# Database — SQLite (default, no setup needed)
# DATABASE_URL=sqlite:///marketplace.db

# Database — MySQL (switch to this when ready)
# Install driver first: pip install PyMySQL
# DATABASE_URL=mysql+pymysql://username:password@localhost:3306/marketplace_db

# Database — PostgreSQL (alternative option)
# Install driver first: pip install psycopg2-binary
# DATABASE_URL=postgresql://username:password@localhost:5432/marketplace_db
